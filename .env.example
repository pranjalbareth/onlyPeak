# OnlyPeak frontend env. Copy to `.env` (gitignored) and adjust.

# YouTube Data API v3 key — used for search
# (https://www.googleapis.com/youtube/v3/search). Create one in the Google Cloud
# Console with the "YouTube Data API v3" enabled. Required for the search feature;
# playback itself uses the public YouTube IFrame player and needs no key.
VITE_YOUTUBE_API_KEY=
